{
  "name": "nordic-art-archive",
  "version": "1.0.0",
  "description": "Front-end UI for the Nordic Art Archive artworks-management web app.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "live-server",
    "lint": "eslint .",
    "format": "prettier --write .",
